INTERLIS 2.3;

MODEL PathThisAreaInNormal (en)
  AT "https://example.com/ilic/regression" VERSION "1" =

  TOPIC T =
    DOMAIN
      Point = COORD 0.000 .. 100.000, 0.000 .. 100.000;

    CLASS A =
      area : AREA WITH (STRAIGHTS) VERTEX Point WITHOUT OVERLAPS > 0.100;
    END A;

    VIEW NormalInspection
      INSPECTION OF A~A->area;
      =
      ATTRIBUTE
        invalid : SURFACE WITH (STRAIGHTS) VERTEX Point WITHOUT OVERLAPS > 0.100
          := THISAREA;
    END NormalInspection;
  END T;

END PathThisAreaInNormal.
