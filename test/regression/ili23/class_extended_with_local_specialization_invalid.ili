INTERLIS 2.3;

MODEL ClassExtendedWithLocalSpecializationInvalid AT "https://example.invalid" VERSION "1" =

  TOPIC BaseTopic =
    CLASS Base =
    END Base;
  END BaseTopic;

  TOPIC ExtendedTopic EXTENDS BaseTopic =
    CLASS Base (EXTENDED) =
    END Base;

    CLASS Specialized EXTENDS BaseTopic.Base =
    END Specialized;
  END ExtendedTopic;

END ClassExtendedWithLocalSpecializationInvalid.
