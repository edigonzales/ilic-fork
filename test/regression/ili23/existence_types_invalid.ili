INTERLIS 2.3;

MODEL ExistenceTypesInvalid (en)
  AT "https://example.com/ilic/regression" VERSION "1" =

  TOPIC T =
    CLASS Source =
      code : 0 .. 99;
    END Source;

    CLASS Target =
      code : TEXT;
      EXISTENCE CONSTRAINT code REQUIRED IN Source:code;
    END Target;
  END T;

END ExistenceTypesInvalid.
