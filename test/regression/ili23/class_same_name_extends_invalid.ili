INTERLIS 2.3;

MODEL ClassSameNameExtendsInvalid AT "https://example.invalid" VERSION "1" =

  TOPIC BaseTopic =
    CLASS Base =
    END Base;
  END BaseTopic;

  TOPIC ExtendedTopic EXTENDS BaseTopic =
    CLASS Base EXTENDS BaseTopic.Base =
    END Base;
  END ExtendedTopic;

END ClassSameNameExtendsInvalid.
