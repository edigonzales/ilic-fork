INTERLIS 2.3;

MODEL InheritedAbstractClassConcretizedValid AT "https://example.invalid" VERSION "1" =

  TOPIC BaseTopic (ABSTRACT) =
    CLASS Base (ABSTRACT) =
    END Base;
  END BaseTopic;

  TOPIC SpecializedTopic EXTENDS BaseTopic =
    CLASS Specialized EXTENDS BaseTopic.Base =
    END Specialized;
  END SpecializedTopic;

  TOPIC ExtendedTopic EXTENDS BaseTopic =
    CLASS Base (EXTENDED) =
    END Base;
  END ExtendedTopic;

END InheritedAbstractClassConcretizedValid.
