INTERLIS 2.4;

MODEL GenericNestedDeferredMissingInvalid AT "https://example.invalid" VERSION "1" =
  DOMAIN
    Position (GENERIC) = COORD NUMERIC, NUMERIC;
    PositionA = COORD 0 .. 100, 0 .. 100;
    PositionB = COORD 200 .. 300, 200 .. 300;
  CONTEXT default =
    Position = PositionA OR PositionB;
  STRUCTURE Geometry =
    edge: POLYLINE WITH (STRAIGHTS) VERTEX Position;
  END Geometry;
  TOPIC Data =
    CLASS Item =
      geometry: Geometry;
    END Item;
  END Data;
END GenericNestedDeferredMissingInvalid.
