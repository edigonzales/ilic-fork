{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ilic.ch/schemas/format-request-v1.schema.json",
  "title": "ilic format request v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "uri"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "uri": { "type": "string", "minLength": 1 },
    "options": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "indentSize": { "type": "integer", "minimum": 1, "maximum": 16, "default": 2 },
        "requireValidSyntax": { "type": "boolean", "default": true }
      }
    }
  }
}
